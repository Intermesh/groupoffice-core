{
  "type": "module",
  "devDependencies": {
    "sass": "latest",
    "typescript": "5.9.*",
    "esbuild": "latest"
  },
  "scripts": {
    "test": "mocha",
    "start": "npm run start:parallel",
    "start:parallel": "npm run start:watch & npm run start:watch-dts & npm run start:sass",
    "start:watch": "node esbuild.mjs watch",
    "start:watch-dts": "npx tsc --watch --emitDeclarationOnly",
    "start:sass": "npx sass --update --load-path=$(npm root) --watch ./style:./dist",

    "build": "npm run build:sass && npm run build:ts",
    "build:clean": "rm -rf ./dist/*",
    "build:sass": "npx sass --update --load-path=$(npm root) --style=compressed ./style:./dist",
    "build:ts": "node esbuild.mjs",
    "build:dts": "npx tsc -b --emitDeclarationOnly",
    "test:ts": "tsc --noEmit",

    "prepare": "npm run build"
  },
  "dependencies": {
    "@intermesh/goui": "latest",
    "@fortaine/fetch-event-source": "latest",
    "chart.js": "latest",
    "ical.js": "2.1.0"
  },
  "author": "Intermesh",
  "license": "LGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Intermesh/groupoffice-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Intermesh/groupoffice-core.git"
  },
  "keywords": [
    "Typescript",
    "Framework",
    "Group-Office"
  ],
  "homepage": "https://github.com/Intermesh/groupoffice-core#readme",
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "name": "@intermesh/groupoffice-core",
  "description": "Run \"npm install\" to install. Then run \"npm start\" for watch mode or build once with \"npm run build\"",
  "version": "2.0.8"


}
