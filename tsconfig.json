{
  "compilerOptions": {
    "strict": true,
    "target": "es2022",
    "sourceMap": true,
    "lib": [
      "es2022",
      "dom"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,
    "module": "preserve",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "composite": true,
    "rootDir": "./script",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
  }
}
