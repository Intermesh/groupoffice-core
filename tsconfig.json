{
  "compilerOptions": {
    "strict": true,
    "target": "es2020",
    "sourceMap": true,
    "lib": [
      "es2020",
      "dom"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,
    "module": "preserve",
    "baseUrl": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "composite": true,
    "rootDir": "./script",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    // removed this as it caused goui to build alongside it
    "paths": {
      "@intermesh/goui": [
        "../goui/dist/index.d.ts",
        "../goui/script/index.ts"
      ]
    }
  },
  "references": [
    { "path": "../goui/" },
  ]

}
